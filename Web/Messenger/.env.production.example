DB_ENGINE=django.db.backends.postgresql
DB_NAME=messenger_db
DB_USER=messenger_user
DB_PASSWORD=change-me-to-strong-production-password
DB_HOST=postgres
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY=change-me-to-long-random-secret-key
DEBUG=False
LOG_LEVEL=INFO
DJANGO_REQUEST_LOG_LEVEL=ERROR
ALLOWED_HOSTS=your-backend-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

MAX_MESSAGE_ATTACHMENT_SIZE=10485760
ALLOWED_MESSAGE_ATTACHMENT_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

THROTTLE_AUTH_RATE=20/hour
THROTTLE_TOKEN_REFRESH_RATE=60/hour
THROTTLE_SEARCH_RATE=60/minute
THROTTLE_MESSAGES_RATE=300/minute
THROTTLE_UPLOADS_RATE=30/hour
THROTTLE_ACTIONS_RATE=300/minute

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=your-smtp-password-or-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL="Messenger <no-reply@example.com>"
FRONTEND_URL=https://your-frontend-domain.com
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

WEBSOCKET_TEST_USERNAME=your-username
WEBSOCKET_TEST_PASSWORD=your-password
WEBSOCKET_TEST_CONVERSATION_ID=1
WEBSOCKET_TEST_API_BASE_URL=https://your-backend-domain.com/api
WEBSOCKET_TEST_WS_BASE_URL=wss://your-backend-domain.com/ws
WEBSOCKET_TEST_TIMEOUT=10
WEBSOCKET_TEST_MESSAGE=Message from WebSocket live update

VITE_API_BASE_URL=https://your-backend-domain.com/api
VITE_WS_BASE_URL=wss://your-backend-domain.com/ws
